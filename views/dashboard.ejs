<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Night Club - Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header class="top-nav">
        <div class="logo-area">
            <h1><span class="kanji">アニメ</span> ANIME NIGHT CLUB <span class="kanji">夜夜</span></h1>
        </div>
        <div class="user-menu">
            <a href="#" onclick="document.getElementById('profile-modal').style.display='flex'" class="edit-profile-btn">👤 Modifica Profilo</a>
            <img src="<%= user.avatarUrl || 'https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150' %>" alt="User Avatar" class="header-avatar" onerror="this.src='https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150'">
            <a href="/logout" class="logout-btn">Logout</a>
        </div>
    </header>

    <div class="dashboard-grid">
        
        <!-- COLONNA SINISTRA (SOLO OWNER) -->
        <aside class="left-sidebar">
            <% if (user.isOwner) { %>
                <div class="panel owner-panel">
                    <h2>OWNER PANEL</h2>
                    <div class="owner-identity">
                        <img src="<%= user.avatarUrl || 'https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150' %>" class="header-avatar" onerror="this.src='https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150'">
                        <span><%= user.username %> (👑 OWNER)</span>
                    </div>
                </div>

                <div class="panel">
                    <h3>SETTA ANIME SETTIMANALE</h3>
                    <form action="/session/start" method="POST" class="neon-form">
                        <label>Cerca su MyAnimeList:</label>
                        <input type="text" id="anime-search" placeholder="Scrivi almeno 3 lettere..." autocomplete="off">
                        <ul id="search-results" class="autocomplete-results"></ul>
                        
                        <input type="hidden" name="anime_title" id="hidden-title">
                        <input type="hidden" name="anime_image_url" id="hidden-image">
                        
                        <div id="selected-anime-preview" class="preview-box">
                            <p>In corso:</p>
                            <img id="preview-image" src="<%= activeSession ? activeSession.anime_image_url : '' %>" onerror="this.style.display='none'">
                            <h4 id="preview-title"><%= activeSession ? activeSession.anime_title : 'Nessun anime selezionato' %></h4>
                        </div>
                        <button type="submit" class="neon-btn primary-btn" id="activate-btn" style="display:none;">ATTIVA QUESTA SESSIONE</button>
                    </form>
                </div>
            <% } else { %>
                <div class="panel">
                    <h2>Membro Panel</h2>
                    <p>Attendi che l'Owner imposti la serata.</p>
                </div>
            <% } %>
        </aside>

        <!-- COLONNA CENTRALE -->
        <main class="main-content">
            <h2 class="welcome-text">BENVENUTO NELLA NIGHT, <%= user.username %>!</h2>

            <div class="content-split">
                <!-- MEMBRI -->
                <div class="panel members-panel">
                    <h3>MEMBRI DEL CLUB</h3>
                    <div class="members-list">
                        <% users.forEach(u => { %>
                            <div class="member-item">
                                <img src="<%= u.avatar_url || 'https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150' %>" alt="<%= u.username %>" class="member-avatar" style="width:40px; height:40px; border-radius:50%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150'">
                                <span class="member-name <%= u.is_owner ? 'owner-name' : '' %>">
                                    <%= u.username %> <%= u.is_owner ? '👑' : '' %>
                                </span>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- CLASSIFICHE -->
                <div class="panel leaderboard-panel">
                    <h3 style="color: #ff0055; margin-bottom: 15px;">🏆 CLASSIFICA GLOBALE</h3>
                    <div class="leaderboard-list">
                        <% if (totalLeaderboard.length > 0) { %>
                            <% totalLeaderboard.forEach((u, index) => { %>
                                <div class="leaderboard-item">
                                    <span class="rank-number"><%= index + 1 %></span>
                                    <img src="<%= u.avatar_url || 'https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150' %>" class="member-avatar" style="width:35px; height:35px; border-radius:50%; object-fit:cover;" onerror="this.src='https://images.unsplash.com/photo-1578632767115-351597cf2477?w=150'">
                                    <span class="username" style="color: <%= index === 0 ? '#ffcc00' : '#fff' %>"><%= u.username %></span>
                                    <span class="score-badge"><%= u.total_score %> pt</span>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="color: #888;">Nessun punto accumulato finora.</p>
                        <% } %>
                    </div>

                    <hr style="border: 1px solid #333; margin: 20px 0;">

                    <h3 style="color: #00f0ff; margin-bottom: 15px;">📺 CLASSIFICHE PER ANIME</h3>
                    <div class="leaderboards-anime">
                        <% if (Object.keys(leaderboardsByAnime).length > 0) { %>
                            <% for (const anime in leaderboardsByAnime) { %>
                                <div class="anime-leaderboard-group" style="background: rgba(255,255,255,0.02); padding: 12px; border-radius: 8px; margin-bottom: 10px;">
                                    <h4 style="border-left: 3px solid #00f0ff; padding-left: 10px; margin-bottom: 10px; font-size: 1em;"><%= anime %></h4>
                                    <% leaderboardsByAnime[anime].forEach((u, index) => { %>
                                        <div class="leaderboard-item" style="padding: 5px 0; background: none; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                            <span class="rank-number" style="font-size: 0.9em; width: 15px;"><%= index + 1 %></span>
                                            <span class="username" style="font-size: 0.9em; margin-left:10px;"><%= u.username %></span>
                                            <span class="score-badge" style="font-size: 0.8em; padding: 2px 6px;"><%= u.score %> pt</span>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p style="color: #888;">Nessun quiz per anime singolo.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>

        <!-- COLONNA DESTRA -->
        <aside class="right-sidebar">
            <div class="panel active-session-panel">
                <h3>SESSIONE ATTIVA</h3>
                <% if (activeSession) { %>
                    <div class="active-poster-container">
                        <img src="<%= activeSession.anime_image_url %>" alt="Poster" class="active-poster" onerror="this.src='https://via.placeholder.com/250x350?text=Nessuna+Immagine'">
                    </div>
                    <h2 class="active-title"><%= activeSession.anime_title %></h2>
                    
                    <div class="quiz-generation-area">
                        <h4 style="color: #ff0055; margin-bottom: 10px;">GENERA IL TUO QUIZ IA</h4>
                        <form action="/generate-quiz" method="POST">
                            <input type="hidden" name="anime_title" value="<%= activeSession.anime_title %>">
                            <input type="hidden" name="session_id" value="<%= activeSession.id %>">
                            <label>Fino a quale episodio hai visto?</label>
                            <input type="number" name="episodes" min="1" required class="neon-input" style="width:100%; margin-bottom:10px;">
                            <button type="submit" class="neon-btn secondary-btn" style="width:100%;">GENERA DOMANDE</button>
                        </form>
                    </div>
                <% } else { %>
                    <p class="waiting-text">In attesa dell'Owner...</p>
                <% } %>
            </div>
        </aside>
    </div>

    <!-- MODALE PROFILO -->
    <div id="profile-modal" class="modal-overlay" style="display:none;">
        <div class="modal-content panel">
            <h3>Modifica Profilo</h3>
            <form action="/profile/update" method="POST">
                <label>URL Immagine Profilo:</label>
                <input type="text" name="avatar_url" class="neon-input" placeholder="https://...immagine.jpg" value="<%= user.avatarUrl || '' %>" required>
                <div style="margin-top: 15px; display: flex; gap: 10px;">
                    <button type="submit" class="neon-btn primary-btn">Salva Modifiche</button>
                    <button type="button" class="neon-btn" onclick="document.getElementById('profile-modal').style.display='none'">Annulla</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Logica per l'autocompletamento MyAnimeList
        const searchInput = document.getElementById('anime-search');
        const resultsList = document.getElementById('search-results');
        const previewImage = document.getElementById('preview-image');
        const previewTitle = document.getElementById('preview-title');
        const hiddenTitle = document.getElementById('hidden-title');
        const hiddenImage = document.getElementById('hidden-image');
        const activateBtn = document.getElementById('activate-btn');

        if(searchInput) {
            let timeout = null;
            searchInput.addEventListener('input', (e) => {
                clearTimeout(timeout);
                const query = e.target.value;
                if (query.length < 3) { resultsList.innerHTML = ''; return; }
                
                timeout = setTimeout(async () => {
                    const res = await fetch(`/api/search-anime?q=${query}`);
                    const animes = await res.json();
                    resultsList.innerHTML = '';
                    animes.forEach(anime => {
                        const li = document.createElement('li');
                        li.textContent = anime.title;
                        li.onclick = () => {
                            previewImage.src = anime.image_url;
                            previewImage.style.display = 'block';
                            previewTitle.textContent = anime.title;
                            hiddenTitle.value = anime.title;
                            hiddenImage.value = anime.image_url;
                            activateBtn.style.display = 'block';
                            resultsList.innerHTML = '';
                            searchInput.value = '';
                        };
                        resultsList.appendChild(li);
                    });
                }, 500);
            });
        }
    </script>
</body>
</html>
