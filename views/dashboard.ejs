<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Night Club - Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dark-theme">
    <header>
        <div class="header-content">
            <div class="logo">
                <span class="jp-text">アニメ</span>
                <span class="en-text">ANIME NIGHT CLUB</span>
                <span class="jp-text">夜夜</span>
            </div>
            <div class="user-status">
                <a href="/profile" style="color: var(--neon-cyan); text-decoration:none; font-weight:600; margin-right:15px;">👤 Modifica Profilo</a>
                <img src="<%= avatarUrl %>" alt="User Avatar" class="header-avatar">
                <a href="/logout" class="btn-logout" style="margin-left: 15px;">Logout</a>
            </div>
        </div>
    </header>

    <main class="dashboard-grid">
        <aside class="panel owner-panel">
            <h2>OWNER PANEL</h2>
            <div class="user-info">
                <img src="<%= avatarUrl %>" alt="Owner Avatar" class="owner-avatar">
                <span><%= user.username %> <%= user.isOwner ? '(👑 OWNER)' : '' %></span>
            </div>
            
            <% if (user.isOwner) { %>
                <div class="anime-selta card">
                    <h3>SETTA ANIME SETTIMANALE</h3>
                    <p style="font-size:0.8rem; color:gray;">Cerca su MyAnimeList:</p>
                    <input type="text" id="mal-search" placeholder="Scrivi almeno 3 lettere...">
                    <div id="mal-results" style="background: rgba(0,0,0,0.5); border-radius:5px;"></div>

                    <form action="/set-anime" method="POST" id="anime-form" style="margin-top:15px; display:none;">
                        <p>Selezionato: <strong id="selected-title-display" style="color:var(--neon-cyan);"></strong></p>
                        <input type="hidden" name="anime_title" id="form-anime-title">
                        <input type="hidden" name="anime_image_url" id="form-anime-image">
                        <button type="submit" class="btn btn-primary">ATTIVA QUESTA SESSIONE</button>
                    </form>

                    <% if (activeSession) { %>
                        <div style="margin-top:20px; text-align:center;">
                            <p>In corso:</p>
                            <img src="<%= activeSession.anime_image_url %>" class="anime-poster">
                            <h4><%= activeSession.anime_title %></h4>
                        </div>
                    <% } %>
                </div>

                <div class="pass-turn card">
                    <h3>PASSA CORONA OWNER</h3>
                    <form action="/pass-owner" method="POST">
                        <select name="new_owner_id">
                            <% otherUsers.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.username %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-warning">PASSA TURNO</button>
                    </form>
                </div>
            <% } else { %>
                <div class="membro-status card">
                    <h3>STATO</h3>
                    <p>Sei un Membro della serata. Attendi che l'Owner scelga l'anime o avvii la room.</p>
                </div>
            <% } %>
        </aside>

        <section class="main-content">
            <div class="card central-card">
                <h2>BENVENUTO NELLA NIGHT, <%= user.username %>!</h2>
                
                <div class="dashboard-panels">
                    <div class="panel-section members-section">
                        <h3>MEMBRI DEL CLUB</h3>
                        <ul class="members-list">
                            <% users.forEach(u => { %>
                                <li class="member-item">
                                    <img src="<%= u.avatar_url %>" alt="<%= u.username %>" class="member-avatar" style="width:35px; height:35px; border-radius:50%;">
                                    <span><%= u.username %> <%= u.is_owner ? '👑' : '' %></span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>

                    <div class="panel-section results-section">
                        <h3>CLASSIFICA ULTIMI QUIZ</h3>
                        <ul class="results-list">
                            <% quizResults.forEach(result => { %>
                                <li class="result-item">
                                    <img src="<%= result.avatar_url %>" class="result-avatar" style="width:30px; height:30px; border-radius:50%;">
                                    <span><strong><%= result.username %></strong></span>
                                    <span class="score" style="margin-left:auto;"><%= result.score %> / 10 Pti</span>
                                    <span class="rating" style="color:var(--neon-yellow); margin-left:10px;"><%= result.rating %> ⭐</span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <aside class="panel member-panel">
            <h2>MEMBER PANEL</h2>
            
            <% if (activeSession) { %>
                <div class="current-quiz card" style="text-align:center;">
                    <h3>SESSIONE ATTIVA</h3>
                    <img src="<%= activeSession.anime_image_url %>" class="anime-poster">
                    <h4><%= activeSession.anime_title %></h4>

                    <div class="generate-quiz-form" style="margin-top:20px; text-align:left;">
                        <h4 style="color:var(--neon-pink);">GENERA IL TUO QUIZ IA</h4>
                        <form action="/generate-quiz" method="POST">
                            <input type="hidden" name="session_id" value="<%= activeSession.id %>">
                            <input type="hidden" name="anime_title" value="<%= activeSession.anime_title %>">
                            
                            <label for="episodes">Fino a quale episodio hai visto?</label>
                            <input type="number" name="episodes" id="episodes" min="1" default="1" required style="width:90%;">
                            
                            <button type="submit" class="btn btn-warning" style="margin-top:10px;">GENERA DOMANDE</button>
                        </form>
                    </div>
                </div>
            <% } else { %>
                <div class="card">
                    <h3>NESSUNA SERATA ATTIVA</h3>
                    <p>L'owner non ha ancora selezionato l'anime della settimana.</p>
                </div>
            <% } %>
        </aside>
    </main>

    <script>
        const searchInput = document.getElementById('mal-search');
        const resultsDiv = document.getElementById('mal-results');
        const animeForm = document.getElementById('anime-form');
        const formTitle = document.getElementById('form-anime-title');
        const formImage = document.getElementById('form-anime-image');
        const displayTitle = document.getElementById('selected-title-display');

        if(searchInput) {
            searchInput.addEventListener('input', async (e) => {
                const val = e.target.value;
                if(val.length < 3) { resultsDiv.innerHTML = ''; return; }

                const res = await fetch(`/api/search-anime?q=${encodeURIComponent(val)}`);
                const items = await res.json();

                resultsDiv.innerHTML = '';
                items.forEach(item => {
                    const div = document.createElement('div');
                    div.style.padding = '8px';
                    div.style.cursor = 'pointer';
                    div.style.borderBottom = '1px solid #333';
                    div.innerHTML = `<img src="${item.image_url}" style="width:30px; vertical-align:middle; margin-right:10px;"> ${item.title}`;
                    
                    div.addEventListener('click', () => {
                        formTitle.value = item.title;
                        formImage.value = item.image_url;
                        displayTitle.innerText = item.title;
                        animeForm.style.display = 'block';
                        resultsDiv.innerHTML = '';
                        searchInput.value = '';
                    });
                    resultsDiv.appendChild(div);
                });
            });
        }
    </script>
</body>
</html>