<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Night Club - Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dark-theme">
    <header>
        <div class="header-content">
            <div class="logo">
                <span class="jp-text">アニメ</span>
                <span class="en-text">ANIME NIGHT CLUB</span>
                <span class="jp-text">夜夜</span>
            </div>
            <div class="user-status">
                <span><%= activeSession ? 'ACTIVE SESSION: ' + activeSession.anime_title : 'NO ACTIVE SESSION' %></span>
                <img src="<%= avatarUrl %>" alt="User Avatar" class="header-avatar">
                <a href="/logout" class="btn-logout">Logout</a>
            </div>
        </div>
    </header>

    <main class="dashboard-grid">
        <aside class="panel owner-panel">
            <h2>OWNER DASHBOARD</h2>
            <div class="user-info">
                <img src="<%= avatarUrl %>" alt="Owner Avatar" class="owner-avatar">
                <span><%= user.username %> <%= user.isOwner ? '(👑 OWNER)' : '' %></span>
            </div>
            
            <% if (user.isOwner) { %>
                <div class="anime-selta card">
                    <h3>ANIME DELLA SETTIMANA</h3>
                    <% if (activeSession) { %>
                        <img src="<%= activeSession.anime_image_url %>" alt="<%= activeSession.anime_title %>" class="anime-poster">
                        <h4><%= activeSession.anime_title %></h4>
                    <% } else { %>
                        <p>Nessun anime scelto.</p>
                    <% } %>
                    <form action="/set-anime" method="POST">
                        <input type="text" name="anime_title" placeholder="Titolo (es. Neon Genesis Evangelion)" required>
                        <input type="url" name="anime_image_url" placeholder="URL Immagine Poster" required>
                        <button type="submit" class="btn btn-primary">SCEGLI ANIME</button>
                    </form>
                </div>

                <div class="quiz-controls card">
                    <h3>GESTIONE QUIZ</h3>
                    <button class="btn btn-secondary">CREA QUIZ (10 Domande)</button>
                    <button class="btn btn-success">GESTISCI MEMBRI</button>
                </div>

                <div class="pass-turn card">
                    <h3>PASSA TURNO (Owner)</h3>
                    <form action="/pass-owner" method="POST">
                        <select name="new_owner_id">
                            <% otherUsers.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.username %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-warning">PASSA CORONA</button>
                    </form>
                </div>
            <% } else { %>
                <div class="membro-status card">
                    <h3>IL TUO STATO</h3>
                    <p>Membro standard. Attendi istruzioni.</p>
                </div>
            <% } %>
        </aside>

        <section class="main-content">
            <div class="card central-card">
                <h2>BENVENUTO, <%= user.username %>!</h2>
                
                <div class="dashboard-panels">
                    <div class="panel-section members-section">
                        <h3>MEMBRI</h3>
                        <ul class="members-list">
                            <% users.forEach(u => { %>
                                <li class="member-item">
                                    <img src="<%= u.avatar_url %>" alt="<%= u.username %>" class="member-avatar">
                                    <span><%= u.username %> <%= u.is_owner ? '👑' : '' %></span>
                                    <span class="status <%= u.is_owner ? 'online' : '' %>"></span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>

                    <div class="panel-section activity-section">
                        <h3>ATTIVITÀ</h3>
                        <ul class="activity-list">
                            <% activityFeed.forEach(activity => { %>
                                <li class="activity-item">
                                    <img src="<%= users.find(u => u.username === activity.username)?.avatar_url %>" alt="<%= activity.username %>" class="activity-avatar">
                                    <div class="activity-text">
                                        <p><strong><%= activity.username %></strong> <%= activity.type === 'online' ? 'è andato online' : (activity.type === 'activity' ? 'ha eseguito attività: ' + activity.detail : 'ha passato il turno owner: ' + activity.detail) %></p>
                                        <span class="activity-time"><%= activity.time %></span>
                                    </div>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>

                <div class="panel-section results-section">
                    <h3>RISULTATI QUIZ RECENTI</h3>
                    <ul class="results-list">
                        <% quizResults.forEach(result => { %>
                            <li class="result-item">
                                <img src="<%= result.avatar_url %>" alt="<%= result.username %>" class="result-avatar">
                                <span><%= result.username %></span>
                                <span class="score"><%= result.score %> / 10</span>
                                <span class="rating"><%= result.rating %>⭐</span>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </section>

        <aside class="panel member-panel">
            <h2>MEMBRO DASHBOARD</h2>
            <div class="user-info">
                <img src="<%= avatarUrl %>" alt="Membro Avatar" class="member-avatar">
                <span><%= user.username %> (Membro)</span>
            </div>

            <% if (activeSession && !user.isOwner) { %>
                <div class="current-quiz card">
                    <h3>IL TUO QUIZ ATTUALE</h3>
                    <img src="<%= activeSession.anime_image_url %>" alt="<%= activeSession.anime_title %>" class="anime-poster">
                    <h4><%= activeSession.anime_title %></h4>

                    <% if (user.currentQuiz) { %>
                        <div class="quiz-status">
                            <h4>LIVE QUIZ: <%= activeSession.anime_title %> (Ep. 1-<%= user.currentQuiz.episodes %>)</h4>
                            <p>Domanda 1/10 <span class="generation-status">GENERAZIONE AI IN CORSO...</span></p>
                             <a href="/take-quiz" class="btn btn-info">FAI IL QUIZ</a>
                        </div>
                    <% } else { %>
                        <div class="generate-quiz-form">
                            <h4>GENERA IL TUO QUIZ</h4>
                            <form action="/generate-quiz" method="POST">
                                <input type="hidden" name="session_id" value="<%= activeSession.id %>">
                                <input type="hidden" name="anime_title" value="<%= activeSession.anime_title %>">
                                <label for="episodes">Episodi visti (es. da 1 a ...):</label>
                                <input type="number" name="episodes" id="episodes" min="1" max="26" required>
                                <button type="submit" class="btn btn-warning">GENERA QUIZ (AI)</button>
                            </form>
                        </div>
                    <% } %>
                </div>
                
                <div class="evaluation card">
                    <h3>VALUTAZIONE ANIME</h3>
                    <form action="/submit-quiz" method="POST">
                        <div class="star-rating">
                            <span class="star">✭</span><span class="star">✭</span><span class="star">✭</span><span class="star">✭</span><span class="star">☆</span>
                            <span>4.5 / 5</span>
                        </div>
                        <button type="submit" class="btn btn-primary" disabled>INVIA QUIZ E VOTO</button>
                    </form>
                </div>
            <% } else { %>
                <div class="card">
                    <h3>ATTENDI SESSIONE</h3>
                    <p>L'owner deve attivare una sessione o tu sei l'owner.</p>
                </div>
            <% } %>
        </aside>
    </main>
</body>
</html>