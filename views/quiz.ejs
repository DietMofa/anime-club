<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz: <%= quiz.anime_title %></title>
    <link rel="stylesheet" href="/style.css">
    <style>
        body { padding: 40px; background-color: var(--bg-dark); }
        .quiz-container { 
            max-width: 800px; 
            margin: 0 auto; 
            background: var(--bg-panel); 
            padding: 40px; 
            border-radius: 10px; 
            border: 1px solid var(--neon-purple); 
            box-shadow: 0 0 20px var(--neon-purple); 
        }
        .question-block { 
            margin-bottom: 25px; 
            background: rgba(255, 255, 255, 0.05); 
            padding: 20px; 
            border-radius: 8px; 
            border-left: 4px solid var(--neon-cyan); 
        }
        .question-title { color: var(--neon-cyan); margin-top: 0; font-size: 1.2rem; }
        label { 
            display: block; 
            margin-bottom: 10px; 
            cursor: pointer; 
            padding: 10px; 
            background: rgba(0,0,0,0.2); 
            border-radius: 5px; 
            transition: background 0.3s; 
        }
        label:hover { background: rgba(0, 188, 212, 0.2); }
        input[type="radio"] { width: auto; margin-right: 10px; accent-color: var(--neon-cyan); }
        
        .rating-block { 
            text-align: center; 
            margin-top: 40px; 
            padding-top: 30px; 
            border-top: 1px solid rgba(255,255,255,0.1); 
        }
        .rating-block input[type="number"] { 
            width: 120px; 
            text-align: center; 
            font-size: 2rem; 
            margin: 10px auto; 
            display: block; 
            font-weight: bold;
            color: var(--neon-yellow);
        }
    </style>
</head>
<body class="dark-theme">
    <div class="quiz-container">
        <h1 style="text-align: center; color: var(--neon-purple); text-shadow: 0 0 10px var(--neon-purple);">
            QUIZ UFFICIALE
        </h1>
        <h3 style="text-align: center; margin-bottom: 30px;">
            <%= quiz.anime_title %> <br>
            <span style="font-size: 0.9em; color: gray;">(Analisi IA fino all'episodio <%= quiz.episodes %>)</span>
        </h3>

        <form action="/submit-quiz" method="POST">
            <!-- Cicla le domande generate dall'IA -->
            <% quiz.data.forEach((q, index) => { %>
                <div class="question-block">
                    <h4 class="question-title"><%= index + 1 %>. <%= q.question %></h4>
                    <% q.options.forEach(opt => { %>
                        <label>
                            <!-- L'IA inserisce sempre l'opzione come stringa -->
                            <input type="radio" name="answers[<%= index %>]" value="<%= opt %>" required>
                            <%= opt %>
                        </label>
                    <% }) %>
                </div>
            <% }) %>

            <!-- Sezione Voto a Stelle -->
            <div class="rating-block">
                <h3 style="color: var(--neon-yellow); text-shadow: 0 0 5px var(--neon-yellow);">IL TUO VOTO (0 - 5)</h3>
                <p style="font-size: 0.9rem; color: gray;">Che voto dai all'anime fino ad ora?</p>
                <input type="number" name="rating" min="0" max="5" step="1" required placeholder="5">
                
                <button type="submit" class="btn btn-primary" style="margin-top: 30px; font-size: 1.2rem; padding: 15px;">
                    INVIA RISPOSTE E VOTO
                </button>
            </div>
        </form>
    </div>
</body>
</html>