<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Night Club - Quiz Time!</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* Aggiunte specifiche per l'impaginazione del quiz */
        .quiz-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
        }
        .question-box {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 25px;
            border-left: 4px solid #00f0ff;
            transition: all 0.3s;
        }
        .question-box:hover {
            background: rgba(255, 255, 255, 0.05);
            border-left: 4px solid #ff0055;
        }
        .question-box h4 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #e0e0ff;
        }
        .options-list {
            list-style: none;
        }
        .options-list li {
            margin-bottom: 10px;
        }
        .options-list label {
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.1rem;
            padding: 8px;
            border-radius: 5px;
        }
        .options-list label:hover {
            background: rgba(0, 240, 255, 0.1);
        }
        input[type="radio"] {
            accent-color: #00f0ff;
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <!-- NAV BAR SUPERIORE -->
    <header class="top-nav">
        <div class="logo-area">
            <h1><span class="kanji">アニメ</span> ANIME NIGHT CLUB <span class="kanji">夜夜</span></h1>
        </div>
        <div class="user-menu">
            <a href="/dashboard" class="neon-btn secondary-btn" style="text-decoration:none;">⬅ Abbandona Quiz</a>
        </div>
    </header>

    <!-- CONTENITORE CENTRALE -->
    <div class="quiz-container">
        <div class="panel">
            <h2 style="color: #00f0ff; margin-bottom: 5px; font-size: 2rem; text-align: center;">QUIZ: <%= quiz.anime_title %></h2>
            <p style="color: #888; margin-bottom: 30px; text-align: center;">Scegli la risposta corretta per guadagnare punti in classifica!</p>

            <form id="quiz-form" action="/submit-quiz" method="POST">
                <input type="hidden" name="session_id" value="<%= quiz.session_id %>">
                <input type="hidden" name="score" id="final-score" value="0">

                <!-- CONTROLLO STRUTTURA IA -->
                <% if (quiz.data && Array.isArray(quiz.data)) { %>
                    
                    <!-- CICLO DELLE DOMANDE -->
                    <% quiz.data.forEach((q, i) => { %>
                        <div class="question-box" data-correct="<%= q.correct_answer || q.correctAnswer || q.correct %>">
                            <h4>Domanda <%= i + 1 %>: <%= q.question %></h4>
                            <ul class="options-list">
                                <% if (q.options && Array.isArray(q.options)) { %>
                                    <% q.options.forEach((opt, j) => { %>
                                        <li>
                                            <label>
                                                <!-- required obbliga l'utente a rispondere a tutto prima di inviare -->
                                                <input type="radio" name="question_<%= i %>" value="<%= opt %>" required>
                                                <%= opt %>
                                            </label>
                                        </li>
                                    <% }) %>
                                <% } %>
                            </ul>
                        </div>
                    <% }) %>

                <% } else { %>
                    <div class="question-box" style="border-left-color: #ff0055;">
                        <h4>Errore Generazione</h4>
                        <p style="color: #ff0055;">L'IA non ha formattato il quiz correttamente. Riprova a generarlo dalla Dashboard.</p>
                    </div>
                <% } %>

                <div style="text-align: center; margin-top: 30px;">
                    <button type="submit" class="neon-btn primary-btn" style="width: 100%; max-width: 400px; font-size: 1.2rem; padding: 15px;">
                        INVIA RISPOSTE 🚀
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- SCRIPT PER CALCOLARE IL PUNTEGGIO AUTOMATICAMENTE -->
    <script>
        document.getElementById('quiz-form').addEventListener('submit', function(e) {
            let score = 0;
            const questions = document.querySelectorAll('.question-box');
            
            // Controlla ogni domanda
            questions.forEach((qBox, index) => {
                const correctAnswer = qBox.getAttribute('data-correct');
                const selectedRadio = document.querySelector(`input[name="question_${index}"]:checked`);
                
                // Se la risposta è giusta (paragonata come stringa), diamo 10 PUNTI!
                if (selectedRadio && selectedRadio.value.trim() === String(correctAnswer).trim()) {
                    score += 10;
                }
            });

            // Imposta il punteggio totale nel campo nascosto prima che il form parta verso il server
            document.getElementById('final-score').value = score;
        });
    </script>
</body>
</html>
